<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="768.0" prefWidth="1200.0" styleClass="root-pane" stylesheets="@../css/global.css, @../css/seller-dashboard.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.onlineauctionsystem.controllers.SellerDashboardController">

    <top>
        <VBox BorderPane.alignment="CENTER">
            <HBox alignment="CENTER_LEFT" prefHeight="35.0" styleClass="seller-top-nav" spacing="20.0">
                <padding><Insets left="40.0" right="40.0" /></padding>
                <children>
                    <Label text="Kênh Người Bán (Seller Center)" styleClass="seller-nav-text" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label text="Hỗ trợ" styleClass="seller-nav-support" />
                </children>
            </HBox>

            <HBox alignment="CENTER_LEFT" prefHeight="75.0" styleClass="seller-main-nav" spacing="20.0">
                <padding><Insets left="40.0" right="40.0" /></padding>
                <children>
                    <VBox alignment="CENTER_LEFT">
                        <Label text="LẠC VIỆT" styleClass="seller-logo-title" />
                        <Label text="AUCTION SYSTEM" styleClass="seller-logo-subtitle" />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox alignment="CENTER_RIGHT" spacing="20.0">
                        <Label fx:id="welcomeLabel" styleClass="text-dark-bold" text="Xin chào, Seller" style="-fx-font-size: 15px;" />
                        <Button mnemonicParsing="false" onAction="#handleLogout" prefHeight="35.0" styleClass="logout-btn" text="Đăng xuất" />
                    </HBox>
                </children>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="20.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="40.0" left="60.0" right="60.0" top="40.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Label styleClass="page-title" text="Quản lý Tài sản Đấu giá" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#handleConfirmPayment" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;" text="✔ ĐÃ THU TIỀN" />
                        <Button mnemonicParsing="false" onAction="#handleCancelAuction" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;" text="✖ HỦY KẾT QUẢ" />

                        <Button mnemonicParsing="false" onAction="#handleEditItem" prefHeight="40.0" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="✎ SỬA" />
                        <Button mnemonicParsing="false" onAction="#handleDeleteItem" prefHeight="40.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="🗑 XÓA" />

                        <Button mnemonicParsing="false" onAction="#handleAddNewItem" prefHeight="40.0" styleClass="primary-btn" text="+ ĐĂNG BÁN MỚI" />
                    </children>
                </HBox>

                <HBox spacing="15.0">
                    <children>
                        <TextField prefHeight="40.0" promptText="Tìm kiếm tên tài sản..." styleClass="filter-box" HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" prefHeight="40.0" prefWidth="100.0" styleClass="search-btn" text="Tìm kiếm" />
                    </children>
                </HBox>

                <TableView fx:id="itemTable" prefHeight="400.0" prefWidth="200.0" VBox.vgrow="ALWAYS" styleClass="seller-table">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="70.0" text="Mã TS" />
                        <TableColumn fx:id="colName" prefWidth="250.0" text="Tên tài sản" />
                        <TableColumn fx:id="colCategory" prefWidth="120.0" text="Phân loại" />
                        <TableColumn fx:id="colStartPrice" prefWidth="120.0" text="Giá khởi điểm" />
                        <TableColumn fx:id="colCurrentBid" prefWidth="130.0" text="Giá cao nhất hiện tại" />
                        <TableColumn fx:id="colStartTime" prefWidth="150" text="Thời gian bắt đầu" />
                        <TableColumn fx:id="colEndTime" prefWidth="150.0" text="Thời gian kết thúc" />
                        <TableColumn fx:id="colStatus" prefWidth="120.0" text="Trạng thái" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </center>
</BorderPane>