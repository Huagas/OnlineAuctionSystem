<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@../css/profile-style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.onlineauctionsystem.controllers.UserPortalController">

    <left>
        <VBox prefWidth="280.0" spacing="10.0" styleClass="sidebar">
            <padding><Insets bottom="20.0" left="15.0" right="15.0" top="40.0" /></padding>
            <children>
                <Region prefHeight="50.0" prefWidth="200.0" />
                <VBox alignment="CENTER" prefWidth="100.0" spacing="10.0" styleClass="form-card">
                    <padding>
                        <Insets bottom="20.0" />
                    </padding>
                    <children>
                        <Button fx:id="btnProfile" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showProfile" text="Thông tin tài khoản" VBox.vgrow="ALWAYS">
                            <styleClass>
                                <String fx:value="menu-item" />
                                <String fx:value="menu-item-active" />
                            </styleClass>
                        </Button>
                        <Button fx:id="btnCart" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="menu-item" text="Giỏ hàng" VBox.vgrow="ALWAYS" />
                        <Button fx:id="btnHistory" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showHistory" styleClass="menu-item" text="Lịch sử đấu giá" VBox.vgrow="ALWAYS" />
                        <Region VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" style="-fx-padding: 20; -fx-background-color: white;" />
    </center>

</BorderPane>
