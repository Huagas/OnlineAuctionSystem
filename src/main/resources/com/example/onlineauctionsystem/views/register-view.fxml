<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" prefWidth="500.0" spacing="20.0" style="-fx-background-color: white;" stylesheets="@../css/register-style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.onlineauctionsystem.controllers.RegisterController">
   <padding>
      <Insets bottom="40.0" left="40.0" right="40.0" top="30.0" />
   </padding>
   <children>
      <VBox alignment="CENTER_LEFT" spacing="5.0">
         <children>
            <Label styleClass="header-title" text="Đăng ký tài khoản" />
            <Label styleClass="header-subtitle" text="Tạo tài khoản để tham gia đấu giá và quản lý giao dịch" />
         </children>
      </VBox>
      <HBox minHeight="50.0" prefHeight="50.0" styleClass="toggle-container">
         <children>
            <Button fx:id="btnSeller" maxWidth="1.7976931348623157E308" minHeight="40.0" mnemonicParsing="false" onAction="#handleToggleRole" prefHeight="40.0" styleClass="toggle-btn-active" text="Bidder" HBox.hgrow="ALWAYS" />
            <Button fx:id="btnBidder" maxWidth="1.7976931348623157E308" minHeight="40.0" mnemonicParsing="false" onAction="#handleToggleRole" prefHeight="40.0" styleClass="toggle-btn-inactive" text="Seller" HBox.hgrow="ALWAYS" />
         </children>
         <VBox.margin>
            <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
         </VBox.margin>
      </HBox>
      <VBox spacing="15.0">
         <children>
            <VBox spacing="2.0">
               <children>
                  <StackPane styleClass="input-group">
                     <children>
                        <TextField fx:id="usernameField" promptText="Nhập thông tin" styleClass="modern-input" />
                        <Label styleClass="input-label" text="Họ và tên" StackPane.alignment="TOP_LEFT" />
                     </children>
                  </StackPane>
                  <Label fx:id="nameErrorLabel" managed="false" styleClass="error-text" visible="false" />
               </children>
            </VBox>
            <VBox spacing="2.0">
               <children>
                  <StackPane styleClass="input-group">
                     <children>
                        <TextField fx:id="emailField" promptText="Nhập thông tin" styleClass="modern-input" />
                        <Label styleClass="input-label" text="Email" StackPane.alignment="TOP_LEFT" />
                     </children>
                  </StackPane>
                  <Label fx:id="emailErrorLabel" managed="false" styleClass="error-text" visible="false" />
               </children>
            </VBox>
            <VBox spacing="2.0">
               <children>
                  <StackPane styleClass="input-group">
                     <children>
                        <TextField fx:id="phoneField" promptText="Nhập thông tin" styleClass="modern-input" />
                        <Label styleClass="input-label" text="Số điện thoại" StackPane.alignment="TOP_LEFT" />
                     </children>
                  </StackPane>
                  <Label fx:id="phoneErrorLabel" managed="false" styleClass="error-text" visible="false" />
               </children>
            </VBox>
            <VBox spacing="5.0">
               <children>
                  <StackPane styleClass="input-group">
                     <children>
                        <PasswordField fx:id="passwordField" promptText="**********" styleClass="modern-input" />
                        <Label styleClass="input-label" text="Mật khẩu" StackPane.alignment="TOP_LEFT" />
                        <Button mnemonicParsing="false" styleClass="eye-btn" text="👁" StackPane.alignment="CENTER_RIGHT" />
                     </children>
                  </StackPane>
                  <Label fx:id="passwordErrorLabel" managed="false" styleClass="error-text" visible="false" />
                  <Label styleClass="hint-text" text="Mật khẩu phải có độ dài từ 8 đến 16 ký tự và chứa ký tự hoa, ký tự thường, ký tự số, ký tự đặc biệt" wrapText="true" />
               </children>
            </VBox>
            <VBox spacing="2.0">
               <children>
                  <StackPane styleClass="input-group">
                     <children>
                        <PasswordField fx:id="confirmPasswordField" promptText="**********" styleClass="modern-input" />
                        <Label styleClass="input-label" text="Xác nhận mật khẩu" StackPane.alignment="TOP_LEFT" />
                        <Button mnemonicParsing="false" styleClass="eye-btn" text="👁" StackPane.alignment="CENTER_RIGHT" />
                     </children>
                  </StackPane>
                  <Label fx:id="confirmPasswordErrorLabel" managed="false" styleClass="error-text" visible="false" />
               </children>
            </VBox>
         </children>
      </VBox>
      <CheckBox fx:id="termsCheckBox" alignment="TOP_LEFT" mnemonicParsing="false" styleClass="terms-checkbox" text="Tôi đồng ý với Điều khoản sử dụng và Chính sách bảo mật" wrapText="true">
         <VBox.margin>
            <Insets top="5.0" />
         </VBox.margin>
      </CheckBox>
      <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleRegister" prefHeight="50.0" styleClass="register-btn" text="Đăng ký" VBox.vgrow="ALWAYS" />
      <HBox alignment="CENTER" spacing="5.0">
         <padding>
            <Insets top="15.0" />
         </padding>
         <children>
            <Label styleClass="login-hint" text="Đã có tài khoản?" />
            <Hyperlink onAction="#handleGoToLogin" styleClass="login-link" text="Đăng nhập" />
         </children>
      </HBox>
   </children>
</VBox>
