<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="700.0" prefWidth="550.0" spacing="15.0" styleClass="dialog-container" stylesheets="@../css/change-password-style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.onlineauctionsystem.controllers.ChangePasswordController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <Label styleClass="title-label" text="Đổi mật khẩu" />

    <VBox spacing="5.0">
        <PasswordField fx:id="oldPassField" minHeight="45.0" promptText="Nhập mật khẩu cũ" styleClass="custom-input" />
        <Label fx:id="oldPassErrorLabel" managed="false" style="-fx-text-fill: #E74C3C; -fx-font-size: 12px;" visible="false" />
    </VBox>

    <VBox spacing="5.0">
        <PasswordField fx:id="newPassField" minHeight="45.0" promptText="Nhập mật khẩu mới" styleClass="custom-input" />
        <Label fx:id="newPassErrorLabel" managed="false" style="-fx-text-fill: #E74C3C; -fx-font-size: 12px;" visible="false" wrapText="true" />
    </VBox>

    <VBox spacing="5.0">
        <PasswordField fx:id="confirmPassField" minHeight="45.0" promptText="Nhập lại mật khẩu mới" styleClass="custom-input" />
        <Label fx:id="confirmPassErrorLabel" managed="false" style="-fx-text-fill: #E74C3C; -fx-font-size: 12px;" visible="false" />
    </VBox>

    <VBox spacing="8.0" styleClass="warning-box">
        <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
        </padding>
        <Label styleClass="warning-title" text="Lưu ý! mật khẩu mới phải thỏa mãn các điều kiện sau:" />
        <Label styleClass="warning-text" text="• Không trùng lặp với mật khẩu gần nhất" />
        <Label styleClass="warning-text" text="• Dài tối thiểu 8 ký tự" />
        <Label styleClass="warning-text" text="• Chữ cái viết hoa (từ A đến Z)" />
        <Label styleClass="warning-text" text="• Chữ cái viết thường (từ a đến z)" />
        <Label styleClass="warning-text" text="• Có ít nhất 1 chữ số" />
        <Label styleClass="warning-text" text="• Có ít nhất 1 ký tự đặc biệt" />
        <Label styleClass="warning-text" text="• Mật khẩu không bao gồm ký tự khoảng trắng" />
    </VBox>

    <Button fx:id="btnNext" maxWidth="Infinity" minHeight="45.0" mnemonicParsing="false" onAction="#handNext" styleClass="next-button" text="Tiếp theo">
        <VBox.margin>
            <Insets top="10.0" />
        </VBox.margin>
    </Button>
</VBox>
