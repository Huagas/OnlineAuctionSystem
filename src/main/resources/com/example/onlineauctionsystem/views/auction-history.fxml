<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox minHeight="800.0" minWidth="985.0" spacing="25.0" style="-fx-background-color: white; -fx-padding: 40;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.onlineauctionsystem.controllers.AuctionHistoryController">
   <children>
      <Label styleClass="header-title" text="Lịch sử đấu giá" />
      <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" spacing="15.0">
         <children>
            <DatePicker fx:id="fromDate" minWidth="180.0" promptText="Thời gian đấu giá từ" styleClass="modern-find" />
            <DatePicker fx:id="toDate" minWidth="180.0" promptText="Đến ngày" styleClass="modern-find" />
            <TextField fx:id="searchField" minWidth="300.0" promptText="Nhập tên sản phẩm" styleClass="modern-find" />
            <Button minHeight="45.0" minWidth="120.0" mnemonicParsing="false" styleClass="find-btn" text="Tìm kiếm" />
         </children>
      </HBox>
      <TableView fx:id="historyTable" prefHeight="200.0" prefWidth="200.0" styleClass="modern-table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colItemName" minWidth="200.0" prefWidth="200.0" text="Sản phẩm" />
            <TableColumn fx:id="colWinningBid" minWidth="150.0" prefWidth="150.0" text="Giá trúng ĐG" />
            <TableColumn fx:id="colMyHighestBid" minWidth="150.0" prefWidth="75.0" text="Giá cao nhất của tôi" />
            <TableColumn fx:id="colBidTime" minWidth="150.0" prefWidth="75.0" text="Thời điểm trả giá" />
            <TableColumn fx:id="colStatus" minWidth="130.0" prefWidth="120.0" text="Trạng thái" />
            <TableColumn fx:id="colAction" minWidth="115.0" prefWidth="95.0" text="Diễn biến" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </children>
   <stylesheets>
      <URL value="@../css/auction-history-style.css" />
   </stylesheets>
</VBox>
